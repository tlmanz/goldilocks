<!DOCTYPE html>
<html lang="en-US">
<head>
  {{ template "head" .Data }}

  {{ if gt (len .Data.VpaData.Namespaces) 1 }} 
  <script src="static/js/filter.js" type="module"></script>
  {{ end }}

  {{- if opts.EnableCost }}
  <noscript>
    <style>
      #email-box, #api-token-box, #cost-settings-box {
        display:none;
      }
    </style>
  </noscript>

  <script>
    window.INSIGHTS_HOST = "{{ opts.InsightsHost }}"
  </script>

  <script defer src="static/js/email.js"></script>
  <script defer src="static/js/api-token.js"></script>
  <script defer src="static/js/cost_settings.js"></script>
  {{- end }}
</head>

<body class="layoutSidebar">
  <header class="layoutSidebar__sidebar">
    {{ template "navigation" . }}
  </header>

  <div class="layoutSidebar__main">
    <main class="verticalRhythm --rhythm-3">

      {{- if opts.EnableCost }}
      {{ template "email" . }}
      {{ template "api_token" . }}
      {{ template "cost_settings" . }}
      {{- end }}

      <header class="pageHeader">
        <div>
          <h1>Namespace Details</h1>
          <p class="pageHeader__meta">
            Updated
            <time
              id="js-generated-at"
              data-unix="{{ .Data.GeneratedAtUnix }}"
            >just now</time>
          </p>
        </div>
        <div class="pageHeader__actions">
          <button
            type="button"
            class="js-export-all linkPill"
            data-format="csv"
            title="Download current + recommended resources for every visible namespace as CSV"
          >
            <i aria-hidden="true" class="fas fa-fw fa-file-csv"></i>
            Export all (CSV)
          </button>
          <button
            type="button"
            class="js-show-reviewed linkPill linkPill--ghost"
            aria-pressed="false"
            title="Toggle visibility of workloads you've marked reviewed"
          >
            <i aria-hidden="true" class="fas fa-fw fa-eye"></i>
            <span class="js-show-reviewed-label">Show reviewed</span>
          </button>
          <label class="autoRefresh" title="Reload the dashboard on a fixed interval">
            <span class="autoRefresh__label">
              <i aria-hidden="true" class="fas fa-fw fa-sync-alt"></i>
              Auto-refresh
            </span>
            <select id="js-autorefresh" class="control-select control-select--small">
              <option value="0">Off</option>
              <option value="30">30s</option>
              <option value="60">1 min</option>
              <option value="300">5 min</option>
            </select>
          </label>
        </div>
      </header>

      {{ template "summary_cards" . }}

      {{ if gt (len .Data.VpaData.Namespaces) 1 }}
        {{ template "filter" .Data.VpaData.Namespaces }}
      {{ end }}

      <div
        class="verticalRhythm --rhythm-3"
        {{ if gt (len .Data.VpaData.Namespaces) 1 }}
        aria-live="off"
        id="js-filter-container"
        {{ end }}
      >
        {{ range $nsName, $nsSummary := .Data.VpaData.Namespaces }}
          {{ template "namespace" $nsSummary }}
        {{end}}
      </div>
    </main>

    <footer>
      {{ template "footer" . }}
    </footer>
  </div>
</body>
</html>
