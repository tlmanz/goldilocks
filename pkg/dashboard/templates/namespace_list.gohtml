<!DOCTYPE html>
<html lang="en-US">
<head>
  {{ template "head" .Data }}

  {{ if gt (len .Data.Namespaces ) 1 }}
  <script src="static/js/filter.js" type="module"></script>
  {{ end }}
</head>

<body class="layoutSidebar">
  <header class="layoutSidebar__sidebar">
    {{ template "navigation" . }}
  </header>

  <div class="layoutSidebar__main">
    <main class="verticalRhythm --rhythm-3">
      <header class="pageHero">
        <div class="pageHero__text">
          <p class="pageHero__eyebrow">Goldilocks</p>
          <h1>Namespaces</h1>
          <p class="pageHero__lead">
            {{ if lt (len .Data.Namespaces) 1 }}
              No namespaces are currently labelled for Goldilocks. Enable one to start getting VPA recommendations.
            {{ else }}
              Browse all namespaces enabled for VPA recommendations. Pick one to dive into per-workload details.
            {{ end }}
          </p>
        </div>
        <div class="pageHero__stat">
          <p class="pageHero__statValue">{{ len .Data.Namespaces }}</p>
          <p class="pageHero__statLabel">Namespaces</p>
        </div>
      </header>

      {{ if lt (len .Data.Namespaces) 1 }}
      <div class="emptyState">
        <i aria-hidden="true" class="fas fa-folder-open emptyState__icon"></i>
        <h2 class="emptyState__title">No namespaces yet</h2>
        <p>Label a namespace to enable VPA recommendations:</p>
        <pre><code class="language-shell">kubectl label ns NAMESPACE_NAME goldilocks.fairwinds.com/enabled=true</code></pre>
      </div>
      {{ else }}
        {{ if gt (len .Data.Namespaces) 1 }}
          {{ template "filter" .Data.Namespaces }}
        {{ end }}

      <ul aria-live="off" class="namespaceList" id="js-filter-container" role="list">
        {{ range .Data.Namespaces }}
        {{ $total := .ContainerCount }}
        {{ $hasStats := gt $total 0 }}
        <li
          data-filter="{{ .Name }}"
          data-namespace="{{ .Name }}"
          data-savings="{{ .SavingsScore }}"
          data-workload-count="{{ .WorkloadCount }}"
          data-needs-attention="{{ .NeedsAttention }}"
        >
          <a class="nsCard" href="{{ $.BasePath }}dashboard/{{ .Name }}">
            <div class="nsCard__top">
              <span class="nsCard__avatar" aria-hidden="true">{{ slice .Name 0 1 }}</span>
              <div class="nsCard__heading">
                <span class="nsCard__name">{{ .Name }}</span>
                {{ if gt .LastRecommendationUnix 0 }}
                <time class="nsCard__updated" data-unix="{{ .LastRecommendationUnix }}">recently</time>
                {{ else }}
                <span class="nsCard__updated nsCard__updated--muted">No VPA data yet</span>
                {{ end }}
              </div>
              <i aria-hidden="true" class="nsCard__arrow fas fa-arrow-right"></i>
            </div>

            <p class="nsCard__counts">
              {{ if $hasStats }}
                <strong>{{ .WorkloadCount }}</strong> workload{{ if ne .WorkloadCount 1 }}s{{ end }}
                · <strong>{{ .ContainerCount }}</strong> container{{ if ne .ContainerCount 1 }}s{{ end }}
              {{ else }}
                <span class="nsCard__counts--muted">No workloads tracked yet</span>
              {{ end }}
            </p>

            {{ if $hasStats }}
            <div
              class="distroBar"
              role="img"
              aria-label="State distribution: {{ .OverCount }} over, {{ .UnderCount }} under, {{ .MissingCount }} unconfigured, {{ .EqualCount }} on target"
            >
              {{ if gt .OverCount 0 }}
              <span class="distroBar__seg distroBar__seg--over" style="flex-grow: {{ .OverCount }}" title="{{ .OverCount }} over-provisioned"></span>
              {{ end }}
              {{ if gt .UnderCount 0 }}
              <span class="distroBar__seg distroBar__seg--under" style="flex-grow: {{ .UnderCount }}" title="{{ .UnderCount }} under-provisioned"></span>
              {{ end }}
              {{ if gt .MissingCount 0 }}
              <span class="distroBar__seg distroBar__seg--missing" style="flex-grow: {{ .MissingCount }}" title="{{ .MissingCount }} unconfigured"></span>
              {{ end }}
              {{ if gt .EqualCount 0 }}
              <span class="distroBar__seg distroBar__seg--equal" style="flex-grow: {{ .EqualCount }}" title="{{ .EqualCount }} on target"></span>
              {{ end }}
            </div>
            {{ end }}

            {{ if or (gt .NeedsAttention 0) (gt .LowConfidence 0) (gt .SavingsScore 0) }}
            <div class="nsCard__chips">
              {{ if gt .NeedsAttention 0 }}
              <span class="statusChip statusChip--attention">
                <i aria-hidden="true" class="fas fa-fw fa-exclamation-circle"></i>
                {{ .NeedsAttention }} need{{ if eq .NeedsAttention 1 }}s{{ end }} attention
              </span>
              {{ end }}
              {{ if gt .LowConfidence 0 }}
              <span class="statusChip statusChip--lowconf">
                <i aria-hidden="true" class="fas fa-fw fa-hourglass-half"></i>
                {{ .LowConfidence }} low confidence
              </span>
              {{ end }}
              {{ if gt .SavingsScore 0 }}
              <span class="statusChip statusChip--savings">
                <i aria-hidden="true" class="fas fa-fw fa-piggy-bank"></i>
                Save ~{{ .SavingsScore }} (CPUm + MiB)
              </span>
              {{ end }}
            </div>
            {{ end }}
          </a>
        </li>
        {{ end }}
      </ul>
      {{end}}
    </main>

    <footer>
      {{ template "footer" . }}
    </footer>
  </div>
</body>
</html>
